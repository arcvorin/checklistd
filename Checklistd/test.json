{
    "version": 1,
    "title": "Checklistd Sample Program",
    "authorName": "Arc Vorin",
    "description": "Testing for science, you monsters!",
    "steps": [
        {
            "type": "input",
            "metadata": { "id": "filtering-question" },
            "input": { "type": "bool" },
            "label": "Did you do the sterile filtering?",
            "key": "didFilter",
            "defaultValue": false,
            "next": "filtering-check"
        },
        {
            "type": "text",
            "metadata": { "id": "filtering-reminder" },
            "message": "Concentration must be measured after sterile filtering.",
            "next": "filtering-question"
        },
        {
            "type": "conditional",
            "metadata": {
                "id": "filtering-check",
                "visible": false
            },
            "condition": {
                "op": "boolean",
                "value": { "var": "didFilter" }
            },
            "true": "filtering-method-question",
            "false": "filtering-reminder"
        },
        {
            "type": "input",
            "metadata": { "id": "filtering-method-question" },
            "input": { "type": "text" },
            "label": "Which filter did you use?",
            "key": "filteringMethod",
            "next": "concentration-text"
        },
        {
            "type": "text",
            "metadata": { "id": "concentration-text" },
            "message": "We need the concentration of the particle stock from UV assay",
            "next": "concentration-input"
        },
        {
            "type": "input",
            "metadata": { "id": "concentration-input" },
            "input": {
                "type": "float",
                "start": 0.3,
                "end": 80
            },
            "label": "[Fe]*DF [mg/mL] -> C (range: 0.3 to 80 mg/mL)",
            "key": "C",
            "next": "particle-input"
        },
        {
            "type": "input",
            "metadata": { "id": "particle-input" },
            "input": {
                "type": "float",
                "start": 0.5,
                "end": 1500
            },
            "label": "How many ugFe are to be injected? (range: 0.5 to 1500 ug)",
            "key": "m",
            "next": "dead-volume-input"
        },
        {
            "type": "input",
            "metadata": { "id": "dead-volume-input" },
            "input": {
                "type": "float",
                "options": {
                    "type": "float",
                    "values": [0.5, 0.7, 1]
                }
            },
            "label": "Choose the dead volume of the syringe? (uL)",
            "key": "Vdead",
            "defaultValue": 0.7,
            "next": "effective-particle-volume-compute"
        },
        {
            "type": "compute",
            "metadata": {
                "id": "effective-particle-volume-compute",
                "visible": false
            },
            "key": "VPeff",
            "expression": "m / C",
            "next": "total-volume-conditional"
        },
        {
            "type": "conditional",
            "metadata": {
                "id": "total-volume-conditional",
                "visible": false
            },
            "condition": {
                "op": "greaterThan",
                "type": "numeric",
                "lhs": { "var": "VPeff" },
                "rhs": 90,
                "orEqual": false
            },
            "true": "set-vt-200",
            "false": "set-vt-100"
        },
        {
            "type": "compute",
            "metadata": {
                "id": "set-vt-200",
                "visible": false
            },
            "key": "VT",
            "expression": "200 + Vdead",
            "next": "set-vp"
        },
        {
            "type": "compute",
            "metadata": {
                "id": "set-vt-100",
                "visible": false
            },
            "key": "VT",
            "expression": "100 + Vdead",
            "next": "set-vp"
        },
        {
            "type": "compute",
            "metadata": {
                "id": "set-vp",
                "visible": false
            },
            "key": "VP",
            "expression": "VPeff * (VT/(VT - Vdead))",
            "next": "sonic-question"
        },
        {
            "type": "input",
            "metadata": { "id": "sonic-question" },
            "input": { "type": "bool" },
            "label": "Did you sonicate the particle stock?",
            "key": "didSonicate",
            "defaultValue": false,
            "next": "sonicate-check"
        },
        {
            "type": "text",
            "metadata": { "id": "sonication-reminder-text" },
            "message": "Sonication of the particle stock is required.",
            "next": "sonic-question"
        },
        {
            "type": "conditional",
            "metadata": {
                "id": "sonicate-check",
                "visible": false
            },
            "condition": {
                "op": "boolean",
                "value": { "var": "didSonicate" }
            },
            "true": "pipette-step-particles",
            "false": "sonication-reminder-text"
        },
        {
            "type": "text",
            "metadata": { "id": "pipette-step-particles" },
            "message": "Pipette {{ VP }} uL from the particle stock",
            "next": "set-vpbs"
        },
        {
            "type": "compute",
            "metadata": {
                "id": "set-vpbs",
                "visible": false
            },
            "key": "VPBS",
            "expression": "0.1 * VT",
            "next": "pipette-step-vpbs"
        },
        {
            "type": "text",
            "metadata": { "id": "pipette-step-vpbs" },
            "message": "Pipette {{ VPBS }} uL from the 10X PBS bottle",
            "next": "set-vw"
        },
        {
            "type": "compute",
            "metadata": {
                "id": "set-vw",
                "visible": false
            },
            "key": "VW",
            "expression": "0.9 * VT - VP",
            "next": "pipette-step-vw"
        },
        {
            "type": "text",
            "metadata": { "id": "pipette-step-vw" },
            "message": "Pipette {{ VW }} uL of sterile filtered water",
            "next": "step-vortex"
        },
        {
            "type": "text",
            "metadata": { "id": "step-vortex" },
            "message": "Vortex the Eppendorf with the solution."
        }
    ]
}
